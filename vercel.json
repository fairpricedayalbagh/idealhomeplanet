{
  "buildCommand": "npx prisma generate --schema=apps/api/prisma/schema.prisma",
  "installCommand": "pnpm install",
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "apps/api/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/rotate-qr",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-checkout",
      "schedule": "59 23 * * *"
    },
    {
      "path": "/api/cron/generate-salary",
      "schedule": "0 2 1 * *"
    }
  ]
}
