{
  "buildCommand": "cd ../.. && pnpm --filter @ihp/shared build && cd apps/api && pnpm exec prisma generate && pnpm exec tsup --config tsup.vercel.ts",
  "installCommand": "cd ../.. && pnpm install",
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/rotate-qr",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-checkout",
      "schedule": "59 23 * * *"
    },
    {
      "path": "/api/cron/generate-salary",
      "schedule": "0 2 1 * *"
    }
  ]
}
